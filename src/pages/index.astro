---
import { Image } from 'astro:assets'
import '../styles/global.css'

import screenshotHoy from '../assets/screenshot-hoy.png'
import screenshotOutfits from '../assets/screenshot-outfits.png'
import screenshotViajes from '../assets/screenshot-viajes.png'
import screenshotPerfil from '../assets/screenshot-perfil.png'
import wardrobeIcon from '../assets/wardrobe-icon.png'

const screenshotWidths = [220, 300, 462, 600, 924]
const spreadSizes = '(max-width: 1060px) 80vw, 300px'

const base = import.meta.env.BASE_URL
const asset = (path: string) => `${base.endsWith('/') ? base : `${base}/`}${path}`
const siteUrl = 'https://nachosizle.github.io'
const pageUrl = new URL(base.endsWith('/') ? base : `${base}/`, siteUrl).toString()
const absoluteAsset = (path: string) => new URL(asset(path), siteUrl).toString()
const title = 'Wardrobe Studio | Tu vestidor digital inteligente'
const description =
  'Wardrobe Studio te ayuda a vestir mejor con lo que ya tienes: organiza tu armario, crea looks, decide qué ponerte y compra con más intención.'

// Las 6 capacidades del Sumario, cada una desarrollada más abajo (mismo id).
// Las que tienen `img` se renderizan como spread con captura; el resto, como entrada de texto.
const sections = [
  {
    no: '01',
    id: 'cap-armario',
    name: 'Armario digital',
    tag: 'Orden',
    title: 'Tu armario, por fin ordenado.',
    body: 'Guarda cada prenda con foto, color, marca y estado para saber siempre qué tienes, qué usas y qué se está quedando olvidado.',
  },
  {
    no: '02',
    id: 'cap-hoy',
    name: 'Outfit del día',
    tag: 'Decisión',
    title: 'Una propuesta clara para hoy.',
    body: 'Abre la app y recibe el look del día con una razón fácil de entender y una acción rápida para guardarlo o pedir otra opción.',
    img: screenshotHoy,
    alt: 'Pantalla Hoy: recomendación de outfit según el tiempo y tu estilo',
    caption: 'Pantalla Hoy — tu recomendación diaria',
  },
  {
    no: '03',
    id: 'cap-looks',
    name: 'Looks editables',
    tag: 'Estilo',
    title: 'Combina hoy, repite cuando quieras.',
    body: 'Crea combinaciones, ajústalas pieza a pieza y guarda tus favoritas. Cuando tengas prisa, recuperas un look que ya sabes que funciona.',
    img: screenshotOutfits,
    alt: 'Pantalla Outfits: crea y descubre combinaciones de ropa',
    caption: 'Pantalla Outfits — combinaciones guardadas',
    reverse: true,
  },
  {
    no: '04',
    id: 'cap-wishlist',
    name: 'Wishlist inteligente',
    tag: 'Compra mejor',
    title: 'Compra con intención, no por impulso.',
    body: 'Guarda lo que estás pensando comprar con precio, enlace e imagen para decidir con calma y evitar la compra impulsiva.',
  },
  {
    no: '05',
    id: 'cap-viajes',
    name: 'Viajes sin exceso',
    tag: 'Maleta',
    title: 'Una maleta que cabe en una idea.',
    body: 'Prepara equipajes más ligeros con prendas que combinan entre sí y cubren tus planes, sin llenar la bolsa “por si acaso”.',
    img: screenshotViajes,
    alt: 'Pantalla Viajes: planifica tu maleta con previsión del tiempo',
    caption: 'Pantalla Viajes — maleta con previsión del tiempo',
  },
]

const insights = [
  'precio amortizado',
  'prendas olvidadas',
  'armario cápsula',
  'lavado y rotación',
  'looks repetidos',
  'resumen anual',
]

const legalBase = 'https://nachosizle.github.io/app-legal/apps/wardrobe-studio'
const legalLinks = [
  ['Política de privacidad', `${legalBase}/privacy-policy`],
  ['Términos de uso', `${legalBase}/terms-of-use`],
  ['Soporte', `${legalBase}/support`],
]

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Wardrobe Studio',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, macOS',
  description,
  url: pageUrl,
  image: absoluteAsset('assets/wardrobe-icon.png'),
  brand: { '@type': 'Brand', name: 'Sizle' },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/PreOrder',
    url: pageUrl,
  },
  featureList: sections.map((section) => section.name),
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={pageUrl} />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href={asset('fonts/Fraunces-latin.woff2')}
    />
    <meta name="theme-color" content="#F7F4F0" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Wardrobe Studio" />
    <meta property="og:image" content={absoluteAsset('assets/wardrobe-icon.png')} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteAsset('assets/wardrobe-icon.png')} />
    <link rel="icon" type="image/png" href={asset('assets/wardrobe-icon.png')} />
    <link rel="apple-touch-icon" href={asset('assets/wardrobe-icon.png')} />
    <link rel="manifest" href={asset('site.webmanifest')} />
    <meta name="application-name" content="Wardrobe Studio" />
    <meta name="apple-mobile-web-app-title" content="Wardrobe Studio" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <title>{title}</title>
  </head>
  <body>
    <header class="masthead" aria-label="Navegación">
      <a class="masthead-brand" href="#top">Wardrobe Studio</a>
      <nav class="masthead-nav" aria-label="Secciones">
        <a href="#sumario">Sumario</a>
        <a href="#cifras">En cifras</a>
        <a href="#editorial">Editorial</a>
      </nav>
      <span class="masthead-issue">Coming soon</span>
    </header>

    <main id="top">
      <!-- 1 · Portada -->
      <section class="cover" aria-labelledby="hero-title">
        <div class="nameplate">
          <span class="nameplate-word">Wardrobe Studio</span>
          <span class="nameplate-issue">Edición Nº01 · Coming soon</span>
        </div>
        <div class="cover-copy">
          <p class="eyebrow">Armario · Looks · Viajes</p>
          <h1 id="hero-title">El armario que <em>piensa</em> contigo.</h1>
          <ul class="coverlines">
            <li>Outfit del día, ya pensado</li>
            <li>Viajes sin exceso, looks que combinan</li>
            <li>Compra con intención, no por impulso</li>
          </ul>
          <div class="cover-actions">
            <span class="button primary">Coming soon</span>
            <a class="button ghost" href="#sumario">Leer la edición</a>
          </div>
          <p class="cover-meta">Lanzamiento en App Store próximamente</p>
        </div>
      </section>

      <span id="nav-sentinel" aria-hidden="true"></span>

      <!-- 2 · Sumario -->
      <section class="contents" id="sumario">
        <div class="contents-head">
          <p class="eyebrow">En este número</p>
          <h2>Sumario</h2>
        </div>
        <ol class="contents-list">
          {
            sections.map((section) => (
              <li>
                <a class="contents-row" href={`#${section.id}`}>
                  <span class="contents-no">{section.no}</span>
                  <span class="contents-title">{section.name}</span>
                  <span class="contents-note">{section.tag}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </section>

      <!-- 3 · Capacidades (feature well) -->
      <section class="spreads" aria-label="Lo que hace Wardrobe Studio">
        {
          sections.map((section) =>
            section.img ? (
              <article class:list={['spread', { reverse: section.reverse }]} id={section.id}>
                <figure class="spread-figure">
                  <Image
                    src={section.img}
                    alt={section.alt}
                    widths={screenshotWidths}
                    sizes={spreadSizes}
                    format="webp"
                    loading="lazy"
                    decoding="async"
                  />
                  <figcaption>{section.caption}</figcaption>
                </figure>
                <div class="spread-copy">
                  <span class="spread-folio">{section.no}</span>
                  <p class="eyebrow">{section.name}</p>
                  <h2>{section.title}</h2>
                  <p>{section.body}</p>
                </div>
              </article>
            ) : (
              <article class="entry" id={section.id}>
                <div class="entry-head">
                  <span class="spread-folio">{section.no}</span>
                  <p class="eyebrow">{section.name}</p>
                </div>
                <div class="entry-body">
                  <h2>{section.title}</h2>
                  <p>{section.body}</p>
                </div>
              </article>
            ),
          )
        }
      </section>

      <!-- 4 · Pull quote -->
      <section class="pullquote">
        <p>Wardrobe no te vende más ropa: te ayuda a vestir mejor con la que ya tienes.</p>
        <span class="pullquote-by">La redacción</span>
      </section>

      <!-- 5 · En cifras (Perfil) -->
      <section class="figures" id="cifras">
        <div class="figures-copy">
          <p class="eyebrow">En cifras · Perfil</p>
          <h2>Tu armario, leído de verdad.</h2>
          <p>
            Descubre qué usas, qué se repite, qué compras se amortizan y qué piezas
            llevan meses esperando una segunda oportunidad.
          </p>
          <div class="insight-list">
            {insights.map((insight) => <span>{insight}</span>)}
          </div>
        </div>
        <figure class="figures-figure">
          <Image
            src={screenshotPerfil}
            alt="Pantalla Perfil: estadísticas de tu armario y paleta de colores"
            widths={screenshotWidths}
            sizes={spreadSizes}
            format="webp"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Pantalla Perfil — estadísticas y paleta</figcaption>
        </figure>
      </section>

      <!-- 6 · Cierre -->
      <section class="closing" id="editorial">
        <figure class="closing-mark">
          <span class="halo" aria-hidden="true"></span>
          <Image
            src={wardrobeIcon}
            alt=""
            width={88}
            height={88}
            densities={[1, 2, 3]}
            format="webp"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <p class="eyebrow">Wardrobe Studio</p>
        <h2>Viste mejor con lo que ya tienes.</h2>
        <span class="button primary">Coming soon</span>
      </section>
    </main>

    <footer class="colophon">
      <span class="colophon-brand">Wardrobe Studio — Edición Nº01</span>
      <nav class="footer-legal" aria-label="Enlaces legales">
        {legalLinks.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
      <span class="colophon-by">Made with &lt;3 by Sizle Digital Product Studio</span>
    </footer>

    <script>
      const header = document.querySelector('.masthead')
      const sentinel = document.getElementById('nav-sentinel')
      if (header && sentinel) {
        const observer = new IntersectionObserver(
          ([entry]) => {
            const scrolledPast = !entry.isIntersecting && entry.boundingClientRect.top < 0
            header.classList.toggle('is-visible', scrolledPast)
          },
          { threshold: 0 },
        )
        observer.observe(sentinel)
      }
    </script>
  </body>
</html>
