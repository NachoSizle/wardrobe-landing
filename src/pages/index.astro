---
import '../styles/global.css'

const base = import.meta.env.BASE_URL
const asset = (path: string) => `${base.endsWith('/') ? base : `${base}/`}${path}`
const siteUrl = 'https://nachosizle.github.io'
const pageUrl = new URL(base.endsWith('/') ? base : `${base}/`, siteUrl).toString()
const absoluteAsset = (path: string) => new URL(asset(path), siteUrl).toString()
const title = 'Wardrobe Studio | Tu vestidor digital inteligente'
const description =
  'Wardrobe Studio convierte tu armario en un sistema inteligente: digitaliza prendas, crea outfits, recibe recomendaciones diarias y planifica viajes.'

const features = [
  {
    title: 'Armario digital',
    body: 'Fotografía tus prendas, clasifícalas por familia, color, marca y estado, y encuentra cualquier pieza sin abrir cajones.',
    eyebrow: 'Captura',
  },
  {
    title: 'Outfit del día',
    body: 'Wardrobe cruza clima, ocasión, fatiga de uso y combinaciones guardadas para proponerte qué ponerte hoy.',
    eyebrow: 'Recomendación',
  },
  {
    title: 'Looks editables',
    body: 'Compón outfits sobre un maniquí editorial, guarda versiones y vuelve a editarlas cuando cambie tu armario.',
    eyebrow: 'Builder',
  },
  {
    title: 'Wishlist inteligente',
    body: 'Guarda prendas desde Safari o tiendas, conserva precio objetivo, URL e imagen, y pásalas al armario al comprarlas.',
    eyebrow: 'Compra mejor',
  },
  {
    title: 'Viajes sin exceso',
    body: 'El planificador genera una maleta mínima para cubrir cada día del viaje según previsión, temperatura y prendas disponibles.',
    eyebrow: 'Packing',
  },
  {
    title: 'Probador AR',
    body: 'Previsualiza un look completo sobre cámara antes de salir y decide con más confianza.',
    eyebrow: 'Try-on',
  },
]

const insights = [
  'coste por uso',
  'piezas en hibernación',
  'score cápsula',
  'lavandería inteligente',
  'historial de looks',
  'Wrapped anual',
]

const steps = [
  ['01', 'Digitaliza', 'Añade prendas desde cámara, biblioteca, código de barras o enlace compartido.'],
  ['02', 'Combina', 'Crea outfits con un builder visual y deja que el motor aprenda tus preferencias.'],
  ['03', 'Decide', 'Recibe un look diario con razones claras: clima, ocasión, color y rotación.'],
  ['04', 'Mejora', 'Mide qué usas, qué no, qué amortizas y qué puede salir de tu armario.'],
]

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Wardrobe Studio',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, macOS',
  description,
  url: pageUrl,
  image: absoluteAsset('assets/wardrobe-icon.png'),
  brand: {
    '@type': 'Brand',
    name: 'Sizle',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/PreOrder',
    url: pageUrl,
  },
  featureList: features.map((feature) => feature.title),
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={pageUrl} />
    <meta name="theme-color" content="#F7F4F0" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Wardrobe Studio" />
    <meta property="og:image" content={absoluteAsset('assets/wardrobe-icon.png')} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteAsset('assets/wardrobe-icon.png')} />
    <link rel="icon" type="image/png" href={asset('assets/wardrobe-icon.png')} />
    <link rel="apple-touch-icon" href={asset('assets/wardrobe-icon.png')} />
    <link rel="manifest" href={asset('site.webmanifest')} />
    <meta name="application-name" content="Wardrobe Studio" />
    <meta name="apple-mobile-web-app-title" content="Wardrobe Studio" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header" aria-label="Navegación principal">
      <a class="brand-lockup" href="#top" aria-label="Wardrobe Studio">
        <img
          src={asset('assets/wardrobe-icon.png')}
          alt=""
          width="34"
          height="34"
          decoding="async"
          fetchpriority="high"
        />
        <span>Wardrobe Studio</span>
      </a>
      <nav>
        <a href="#producto">Producto</a>
        <a href="#sistema">Sistema</a>
        <a href="#privacidad">Privacidad</a>
      </nav>
      <span class="nav-cta">Coming soon</span>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-orbit" aria-hidden="true">
          <div class="orbit-chip chip-one">Clima 18 ºC</div>
          <div class="orbit-chip chip-two">Coste/uso 1,84 €</div>
          <div class="orbit-chip chip-three">Look guardado</div>
        </div>

        <div class="hero-copy">
          <p class="kicker">iPhone · macOS · Widget</p>
          <h1 id="hero-title">Tu armario empieza a pensar contigo.</h1>
          <p class="hero-lede">
            Wardrobe Studio transforma tus prendas en un vestidor vivo: captura,
            combina, recomienda y mide para que cada mañana tengas menos duda y más estilo.
          </p>
          <div class="hero-actions" id="download">
            <span class="button primary">Coming soon</span>
            <a class="button secondary" href="#producto">Ver lo que hace</a>
          </div>
          <p class="cta-note">Lanzamiento en App Store próximamente.</p>
        </div>

        <!-- TODO: replace this illustrative mockup with real screenshots from the Wardrobe iOS app. -->
        <div class="product-stage" aria-label="Vista previa de Wardrobe Studio">
          <div class="phone phone-main">
            <div class="phone-top">
              <span>MAR · 19 MAY</span>
              <span>18 ºC</span>
            </div>
            <h2>Tu outfit del día</h2>
            <div class="look-stack">
              <div class="garment top-piece">
                <span>Blazer lino</span>
              </div>
              <div class="garment bottom-piece">
                <span>Pantalón recto</span>
              </div>
              <div class="garment shoe-piece">
                <span>Mocasines</span>
              </div>
            </div>
            <div class="reason">
              Ligero para la tarde, formal sin exceso y con rotación equilibrada.
            </div>
            <div class="phone-cta">Lo llevo hoy</div>
          </div>
          <div class="phone phone-side" aria-hidden="true">
            <div class="mini-grid">
              <div><img src={asset('assets/dress.svg')} alt="" width="44" height="44" /></div>
              <div><img src={asset('assets/pants.svg')} alt="" width="44" height="44" /></div>
              <div><img src={asset('assets/skirt.svg')} alt="" width="44" height="44" /></div>
              <div class="text-tile">+42</div>
            </div>
            <p>Armario</p>
          </div>
        </div>
      </section>

      <section class="proof-strip" aria-label="Resumen del producto">
        <div>
          <strong>SwiftUI nativo</strong>
          <span>Diseñado para sentirse Apple, no web envuelta.</span>
        </div>
        <div>
          <strong>Weather-aware</strong>
          <span>Looks diarios con clima, ocasión y rotación.</span>
        </div>
        <div>
          <strong>Menos ruido</strong>
          <span>Decisiones útiles, no configuración infinita.</span>
        </div>
      </section>

      <section class="section intro" id="producto">
        <div class="section-heading">
          <p class="kicker">Producto</p>
          <h2>Un estudio personal para vestir con intención.</h2>
        </div>
        <p class="section-copy">
          La app no intenta venderte más ropa. Te ayuda a entender la que ya tienes,
          recordar lo que quieres comprar de verdad y convertir cada look aceptado en historial útil.
        </p>
      </section>

      <section class="feature-grid" aria-label="Funcionalidades de Wardrobe Studio">
        {
          features.map((feature) => (
            <article class="feature-card">
              <span>{feature.eyebrow}</span>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </article>
          ))
        }
      </section>

      <section class="system-section" id="sistema">
        <div class="system-visual">
          <div class="dashboard-window">
            <div class="window-bar">
              <span></span><span></span><span></span>
            </div>
            <div class="dashboard-content">
              <div>
                <p class="kicker">Perfil de estilo</p>
                <h2>De prendas sueltas a señales accionables.</h2>
              </div>
              <div class="metric-row">
                <div><strong>128</strong><span>prendas</span></div>
                <div><strong>31</strong><span>outfits</span></div>
                <div><strong>74%</strong><span>cápsula</span></div>
              </div>
              <div class="bars" aria-hidden="true">
                <i style="height: 42%"></i>
                <i style="height: 76%"></i>
                <i style="height: 58%"></i>
                <i style="height: 86%"></i>
                <i style="height: 64%"></i>
                <i style="height: 92%"></i>
              </div>
            </div>
          </div>
        </div>
        <div class="system-copy">
          <p class="kicker">Sistema Wardrobe</p>
          <h2>El valor aparece después del tercer uso, no en el primer formulario.</h2>
          <p>
            Wardrobe registra wear logs por prenda, guarda snapshots de looks aceptados,
            genera razones comprensibles y convierte patrones invisibles en decisiones sencillas.
          </p>
          <div class="insight-list">
            {insights.map((insight) => <span>{insight}</span>)}
          </div>
        </div>
      </section>

      <section class="steps-section" aria-label="Cómo funciona">
        <div class="section-heading">
          <p class="kicker">Flujo</p>
          <h2>Cuatro gestos. Un armario que mejora solo.</h2>
        </div>
        <div class="steps">
          {
            steps.map(([number, title, body]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="travel-band">
        <div>
          <p class="kicker">Viajes · Widget · AR</p>
          <h2>Cuando sales de casa, Wardrobe sigue contigo.</h2>
        </div>
        <p>
          Planifica maletas, revisa el look del día desde el widget, prueba combinaciones
          con cámara y comparte tarjetas de lookbook con estética editorial.
        </p>
      </section>

      <section class="native-section" id="privacidad">
        <div class="native-copy">
          <p class="kicker">Privacidad · Nativo · Sin ruido</p>
          <h2>Un armario inteligente no necesita convertirte en un feed.</h2>
          <p>
            Wardrobe está pensado como una herramienta personal: tus prendas, tus looks,
            tus métricas y tus decisiones. Sin catálogo infinito, sin presión de compra
            y sin convertir cada mañana en otra pantalla que revisar.
          </p>
        </div>
        <div class="native-panel" aria-label="Principios del producto">
          <article>
            <span>Local-first</span>
            <strong>SwiftData para que tu armario responda al instante.</strong>
          </article>
          <article>
            <span>Contextual</span>
            <strong>Clima, ocasión y rotación explicados con razones claras.</strong>
          </article>
          <article>
            <span>Accionable</span>
            <strong>Hibernación, coste por uso y cápsula para mejorar sin comprar más.</strong>
          </article>
        </div>
      </section>

      <section class="final-cta">
        <img
          src={asset('assets/wardrobe-icon.png')}
          alt=""
          width="96"
          height="96"
          loading="lazy"
          decoding="async"
        />
        <p class="kicker">Wardrobe Studio</p>
        <h2>Viste mejor con lo que ya tienes.</h2>
        <span class="button primary">Coming soon</span>
      </section>
    </main>

    <footer>
      <span>Wardrobe Studio</span>
      <span>iOS · macOS · Coming soon</span>
    </footer>
  </body>
</html>
