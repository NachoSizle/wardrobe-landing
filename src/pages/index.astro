---
import { Image } from 'astro:assets'
import '../styles/global.css'

import screenshotHoy from '../assets/screenshot-hoy.png'
import screenshotOutfits from '../assets/screenshot-outfits.png'
import screenshotViajes from '../assets/screenshot-viajes.png'
import screenshotPerfil from '../assets/screenshot-perfil.png'
import wardrobeIcon from '../assets/wardrobe-icon.png'

const screenshotWidths = [220, 300, 462, 600, 924]
const screenshotSizes = '(max-width: 720px) 220px, (max-width: 1060px) 45vw, 300px'

const base = import.meta.env.BASE_URL
const asset = (path: string) => `${base.endsWith('/') ? base : `${base}/`}${path}`
const siteUrl = 'https://nachosizle.github.io'
const pageUrl = new URL(base.endsWith('/') ? base : `${base}/`, siteUrl).toString()
const absoluteAsset = (path: string) => new URL(asset(path), siteUrl).toString()
const title = 'Wardrobe Studio | Tu vestidor digital inteligente'
const description =
  'Wardrobe Studio te ayuda a vestir mejor con lo que ya tienes: organiza tu armario, crea looks, decide qué ponerte y compra con más intención.'

const features = [
  {
    title: 'Armario digital',
    body: 'Guarda tus prendas con foto, color, marca y estado para saber siempre qué tienes, qué usas y qué se está quedando olvidado.',
    eyebrow: 'Orden',
  },
  {
    title: 'Outfit del día',
    body: 'Abre la app y recibe una propuesta clara para hoy, con una razón fácil de entender y una acción rápida para guardarla.',
    eyebrow: 'Decisión',
  },
  {
    title: 'Looks editables',
    body: 'Crea combinaciones, ajusta piezas, guarda tus favoritas y vuelve a ellas cuando quieras repetir o mejorar un look.',
    eyebrow: 'Estilo',
  },
  {
    title: 'Wishlist inteligente',
    body: 'Guarda lo que estás pensando comprar con precio, enlace e imagen para decidir con calma y evitar compras impulsivas.',
    eyebrow: 'Compra mejor',
  },
  {
    title: 'Viajes sin exceso',
    body: 'Prepara una maleta más ligera con prendas que combinan entre sí y cubren tus planes sin llenar la bolsa “por si acaso”.',
    eyebrow: 'Maleta',
  },
  {
    title: 'Pruébate el look',
    body: 'Previsualiza combinaciones antes de salir para decidir con más confianza y evitar cambios de última hora.',
    eyebrow: 'Confianza',
  },
]

const insights = [
  'precio amortizado',
  'prendas olvidadas',
  'armario cápsula',
  'lavado y rotación',
  'looks repetidos',
  'resumen anual',
]

const steps = [
  ['01', 'Añade', 'Guarda tus prendas con foto, color, marca, precio y notas útiles.'],
  ['02', 'Combina', 'Crea looks que puedas repetir, editar y recuperar cuando tengas prisa.'],
  ['03', 'Decide', 'Recibe una propuesta diaria pensada para tus planes, tu estilo y tu rotación.'],
  ['04', 'Mejora', 'Descubre qué usas, qué amortizas y qué puede salir de tu armario.'],
]

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Wardrobe Studio',
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'iOS, macOS',
  description,
  url: pageUrl,
  image: absoluteAsset('assets/wardrobe-icon.png'),
  brand: {
    '@type': 'Brand',
    name: 'Sizle',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/PreOrder',
    url: pageUrl,
  },
  featureList: features.map((feature) => feature.title),
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={pageUrl} />
    <meta name="theme-color" content="#F7F4F0" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Wardrobe Studio" />
    <meta property="og:image" content={absoluteAsset('assets/wardrobe-icon.png')} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteAsset('assets/wardrobe-icon.png')} />
    <link rel="icon" type="image/png" href={asset('assets/wardrobe-icon.png')} />
    <link rel="apple-touch-icon" href={asset('assets/wardrobe-icon.png')} />
    <link rel="manifest" href={asset('site.webmanifest')} />
    <meta name="application-name" content="Wardrobe Studio" />
    <meta name="apple-mobile-web-app-title" content="Wardrobe Studio" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header" aria-label="Navegación principal">
      <a class="brand-lockup" href="#top" aria-label="Wardrobe Studio">
        <Image
          src={wardrobeIcon}
          alt=""
          width={34}
          height={34}
          densities={[1, 2, 3]}
          format="webp"
          decoding="async"
          fetchpriority="high"
        />
        <span>Wardrobe Studio</span>
      </a>
      <nav>
        <a href="#producto">Producto</a>
        <a href="#sistema">Sistema</a>
        <a href="#privacidad">Privacidad</a>
      </nav>
      <span class="nav-cta">Coming soon</span>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="kicker">Armario · Looks · Viajes</p>
          <h1 id="hero-title">Tu armario empieza a pensar contigo.</h1>
          <p class="hero-lede">
            Wardrobe Studio transforma tus prendas en un vestidor vivo: captura,
            combina, recomienda y mide para que cada mañana tengas menos duda y más estilo.
          </p>
          <div class="hero-actions" id="download">
            <span class="button primary">Coming soon</span>
            <a class="button secondary" href="#producto">Ver lo que hace</a>
          </div>
          <p class="cta-note">Lanzamiento en App Store próximamente.</p>
        </div>
      </section>

      <section class="screenshots-section" aria-label="Capturas de pantalla de Wardrobe Studio">
        <p class="kicker screenshots-kicker">La app, en acción</p>
        <div class="screenshots-strip">
          <figure class="screenshot-card">
            <Image
              src={screenshotHoy}
              alt="Pantalla Hoy: recomendación de outfit según el tiempo y tu estilo"
              widths={screenshotWidths}
              sizes={screenshotSizes}
              format="webp"
              fetchpriority="high"
              loading="eager"
              decoding="async"
            />
          </figure>
          <figure class="screenshot-card">
            <Image
              src={screenshotOutfits}
              alt="Pantalla Outfits: crea y descubre combinaciones de ropa"
              widths={screenshotWidths}
              sizes={screenshotSizes}
              format="webp"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <figure class="screenshot-card">
            <Image
              src={screenshotViajes}
              alt="Pantalla Viajes: planifica tu maleta con previsión del tiempo"
              widths={screenshotWidths}
              sizes={screenshotSizes}
              format="webp"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <figure class="screenshot-card">
            <Image
              src={screenshotPerfil}
              alt="Pantalla Perfil: estadísticas de tu armario y paleta de colores"
              widths={screenshotWidths}
              sizes={screenshotSizes}
              format="webp"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
      </section>

      <section class="proof-strip" aria-label="Resumen del producto">
        <div>
          <strong>Menos dudas</strong>
          <span>Una propuesta concreta para esos días en los que no sabes qué ponerte.</span>
        </div>
        <div>
          <strong>Compra con cabeza</strong>
          <span>Wishlist con contexto para decidir después, no comprar por impulso.</span>
        </div>
        <div>
          <strong>Maletas ligeras</strong>
          <span>Combinaciones pensadas para viajar sin llevar medio armario.</span>
        </div>
      </section>

      <section class="section intro" id="producto">
        <div class="section-heading">
          <p class="kicker">Producto</p>
          <h2>Una forma más tranquila de entender tu estilo.</h2>
        </div>
        <p class="section-copy">
          Wardrobe no intenta venderte más ropa. Te ayuda a usar mejor la que ya tienes,
          recordar lo que vale la pena comprar y convertir cada look en una decisión más fácil.
        </p>
      </section>

      <section class="feature-grid" aria-label="Funcionalidades de Wardrobe Studio">
        {
          features.map((feature) => (
            <article class="feature-card">
              <span>{feature.eyebrow}</span>
              <h3>{feature.title}</h3>
              <p>{feature.body}</p>
            </article>
          ))
        }
      </section>

      <section class="system-section" id="sistema">
        <div class="system-visual">
          <div class="dashboard-window">
            <div class="window-bar">
              <span></span><span></span><span></span>
            </div>
            <div class="dashboard-content">
              <div>
                <p class="kicker">Tu armario, leído de verdad</p>
                <h2>Lo que usas cuenta una historia. Wardrobe te la enseña.</h2>
              </div>
              <div class="metric-row">
                <div><strong>128</strong><span>prendas</span></div>
                <div><strong>31</strong><span>outfits</span></div>
                <div><strong>74%</strong><span>en rotación</span></div>
              </div>
              <div class="bars" aria-hidden="true">
                <i style="height: 42%"></i>
                <i style="height: 76%"></i>
                <i style="height: 58%"></i>
                <i style="height: 86%"></i>
                <i style="height: 64%"></i>
                <i style="height: 92%"></i>
              </div>
            </div>
          </div>
        </div>
        <div class="system-copy">
          <p class="kicker">Progreso visible</p>
          <h2>Cada look guardado hace que tu armario sea más fácil de usar.</h2>
          <p>
            La app te ayuda a ver qué prendas funcionan, cuáles se repiten demasiado,
            qué compras se amortizan y qué piezas llevan meses esperando una segunda oportunidad.
          </p>
          <div class="insight-list">
            {insights.map((insight) => <span>{insight}</span>)}
          </div>
        </div>
      </section>

      <section class="steps-section" aria-label="Cómo funciona">
        <div class="section-heading">
          <p class="kicker">Flujo</p>
          <h2>Cuatro gestos. Un armario que mejora solo.</h2>
        </div>
        <div class="steps">
          {
            steps.map(([number, title, body]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="travel-band">
        <div>
          <p class="kicker">Viajes · Wishlist · Probador</p>
          <h2>Cuando sales de casa, Wardrobe sigue contigo.</h2>
        </div>
        <p>
          Planifica maletas, recupera looks que ya sabes que funcionan, prueba combinaciones
          antes de salir y comparte tarjetas de lookbook con estética editorial.
        </p>
      </section>

      <section class="calm-section" id="privacidad">
        <div class="calm-copy">
          <p class="kicker">Privado · Calmado · Personal</p>
          <h2>Tu armario no necesita convertirse en otra red social.</h2>
          <p>
            Wardrobe está pensado como una herramienta personal: tus prendas, tus looks,
            tus métricas y tus decisiones. Sin catálogo infinito, sin presión de compra
            y sin convertir cada mañana en otra pantalla que revisar.
          </p>
        </div>
        <div class="calm-panel" aria-label="Principios del producto">
          <article>
            <span>Tuyo</span>
            <strong>Tu armario se organiza alrededor de tus prendas reales, no de tendencias externas.</strong>
          </article>
          <article>
            <span>Contextual</span>
            <strong>Cada recomendación explica por qué encaja con tu día y tu forma de vestir.</strong>
          </article>
          <article>
            <span>Accionable</span>
            <strong>Detecta prendas olvidadas, compras amortizadas y piezas que puedes rotar fuera.</strong>
          </article>
        </div>
      </section>

      <section class="final-cta">
        <Image
          src={wardrobeIcon}
          alt=""
          width={96}
          height={96}
          densities={[1, 2, 3]}
          format="webp"
          loading="lazy"
          decoding="async"
        />
        <p class="kicker">Wardrobe Studio</p>
        <h2>Viste mejor con lo que ya tienes.</h2>
        <span class="button primary">Coming soon</span>
      </section>
    </main>

    <footer>
      <span>Wardrobe Studio</span>
      <span>Made with &lt;3 by Sizle Digital Product Studio</span>
    </footer>
  </body>
</html>
